{
  "id": "wakeword-trainer",
  "name": "Wake Word Trainer",
  "version": "0.0.2",
  "enabled": true,
  "nav": {
    "label": "Wake Word Trainer",
    "icon": "model_training",
    "to": "/wakeword-trainer"
  },
  "dashboards": [],
  "exports": [
    { "id": "WakeWordTab", "type": "component" }
  ],
  "service": {
    "settingPath": "wake.trainer_url",
    "spawnModule": "yz_wakeword_trainer",
    "autoSpawnSettingPath": "wake.trainer_auto_spawn",
    "proxy": {
      "prefix": "/api/wakeword-trainer",
      "graceS": 30,
      "timeoutS": 30
    },
    "events": {
      "channels": ["wakeword_state"],
      "path": "/events"
    }
  },
  "settings": {}
}
