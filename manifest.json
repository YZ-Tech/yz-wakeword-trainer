{
  "id": "wakeword-trainer",
  "name": "Wake Word Trainer",
  "version": "0.0.6",
  "enabled": true,
  "dashboards": [],
  "exports": [
    {
      "id": "WakeWordTab",
      "type": "component"
    }
  ],
  "service": {
    "url": "http://127.0.0.1:9001",
    "settingPath": "wake.trainer_url",
    "spawnModule": "yz_wakeword_trainer",
    "autoSpawnSettingPath": "wake.trainer_auto_spawn",
    "proxy": {
      "prefix": "/api/wakeword-trainer",
      "graceS": 30,
      "timeoutS": 30
    },
    "events": {
      "channels": [
        "wakeword_state"
      ],
      "path": "/events"
    }
  },
  "settings": {},
  "requires": {
    "network": "setup",
    "sensors": [
      "mic"
    ]
  }
}
